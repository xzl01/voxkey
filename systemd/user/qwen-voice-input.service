[Unit]
Description=Qwen3-ASR push-to-talk voice input
After=graphical-session.target pipewire.service

[Service]
Type=simple
WorkingDirectory=%h/AI/VoiceInput
ExecStart=%h/AI/VoiceInput/run.sh
Restart=on-failure
RestartSec=2

[Install]
WantedBy=default.target
