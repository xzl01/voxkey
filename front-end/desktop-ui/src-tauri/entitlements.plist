<?xml version="1.0" encoding="UTF-8"?>
<plist version="1.0">
<dict>
  <!-- Allow the bundled Python / onnxruntime / llama.cpp to use the JIT and
       executable memory they need under the hardened runtime. Required for a
       notarized (signed) build to actually run the ASR engines. Harmless for
       an ad-hoc / unsigned dev build (entitlements are only applied when the
       app is codesigned). -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
